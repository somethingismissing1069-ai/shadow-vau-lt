# ─── Docker Compose Environment Variables ─────────────────────────
# Copy this file to .env and fill in the values before running docker-compose up

# ─── Domain ───────────────────────────────────────────────────────
DOMAIN=shadowvault.io

# ─── Database ─────────────────────────────────────────────────────
DB_PASSWORD=<strong-database-password>

# ─── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=<64-byte-hex-secret>

# ─── Notes ────────────────────────────────────────────────────────
# 1. Generate DB_PASSWORD:  openssl rand -hex 32
# 2. Generate JWT_SECRET:   openssl rand -hex 64
# 3. Place TLS certs in:    ./nginx/certs/fullchain.pem and ./nginx/certs/privkey.pem
# 4. Place RSA key in:      ./secrets/rsa_private_key.pem
#
# For development TLS certs:
#   openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
#     -keyout ./nginx/certs/privkey.pem -out ./nginx/certs/fullchain.pem \
#     -subj "/CN=localhost"
#
# For RSA private key:
#   openssl genpkey -algorithm RSA -out ./secrets/rsa_private_key.pem -pkeyopt rsa_keygen_bits:4096
