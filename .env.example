# ─── Server ───────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
BASE_URL=https://shadowvault.io
CORS_ORIGINS=https://shadowvault.io

# ─── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://sv:secret@db:5432/shadowvault

# ─── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=<64-byte-hex-secret>
JWT_ACCESS_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=604800

# ─── Encryption ───────────────────────────────────────────────────
RSA_PRIVATE_KEY_PATH=/run/secrets/rsa_private_key
UPLOAD_DIR=/data/encrypted
MAX_UPLOAD_BYTES=104857600

# ─── Rate Limiting ────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Cleanup ──────────────────────────────────────────────────────
EXPIRY_CRON_SCHEDULE=*/5 * * * *
